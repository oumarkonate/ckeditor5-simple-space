{
	"name": "ckeditor5-simple-space",
	"version": "1.0.0",
	"description": "CKEditor 5 plugin that visualizes regular space characters in the editing area, with a toolbar toggle. Editing-view only — the content data is never altered.",
	"keywords": [
		"ckeditor",
		"ckeditor5",
		"ckeditor 5",
		"ckeditor5-feature",
		"ckeditor5-plugin",
		"ckeditor5-dll",
		"whitespace",
		"spaces",
		"invisible-characters",
		"formatting-marks"
	],
	"type": "module",
	"main": "src/index.js",
	"exports": {
		".": "./src/index.js",
		"./theme/simplespace.css": "./theme/simplespace.css",
		"./package.json": "./package.json"
	},
	"files": [
		"src",
		"theme"
	],
	"scripts": {
		"test": "jest",
		"test:coverage": "jest --coverage",
		"lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
		"sample": "vite"
	},
	"peerDependencies": {
		"ckeditor5": ">=47.3.0"
	},
	"devDependencies": {
		"@babel/core": "^7.24.0",
		"@babel/preset-env": "^7.24.0",
		"babel-jest": "^29.7.0",
		"ckeditor5": "^48.0.0",
		"eslint": "^8.57.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"vite": "^5.4.0"
	},
	"license": "MIT",
	"author": "Oumar Konaté",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oumarkonate/ckeditor5-simple-space.git"
	},
	"bugs": {
		"url": "https://github.com/oumarkonate/ckeditor5-simple-space/issues"
	},
	"homepage": "https://github.com/oumarkonate/ckeditor5-simple-space#readme"
}
